#
# Copy this file to `.env` and fill in only the provider settings you need.
#
# Usage:
#   cp .env.example .env
#   source .env
#

#
# Common app settings
#
export PYTHONPATH="/Users/koustubh/Documents/modern-app/app"

#
# OpenAI provider
#
# export OPENAI_API_KEY="your-openai-api-key"
# export MODERNIZE_OPENAI_MODEL="gpt-4o-mini"

#
# Anthropic provider
#
# export ANTHROPIC_API_KEY="your-anthropic-api-key"
# export MODERNIZE_ANTHROPIC_MODEL="claude-3-7-sonnet-latest"

#
# Gemini provider: API key mode
#
# export GEMINI_API_KEY="your-gemini-api-key"
# export GOOGLE_API_KEY="your-google-api-key"
# export MODERNIZE_GEMINI_MODEL="gemini-2.5-flash"

#
# Gemini provider: Vertex AI / ADC mode
# Use either personal ADC:
#   gcloud auth application-default login
# Or a service account:
#   export GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"
#
# export GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"
# export GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# export GOOGLE_CLOUD_LOCATION="global"
# export GOOGLE_GENAI_USE_VERTEXAI="true"
# export MODERNIZE_GEMINI_MODEL="gemini-2.5-flash"

#
# command-json provider
#
# export MODERNIZE_AI_COMMAND="python3 /absolute/path/to/your/provider_script.py"

